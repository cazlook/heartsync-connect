# HeartsSync Backend v2 - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# MongoDB
MONGO_URI=mongodb://localhost:27017/heartsync_v2

# JWT (use strong random secrets in production)
JWT_SECRET=change-this-to-a-strong-random-secret-at-least-64-chars
JWT_EXPIRES=15m
REFRESH_EXPIRES=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3001

# Signal Processing (optional overrides)
# Z_THRESHOLD=1.5
# MIN_DURATION_SEC=2.5
# MAX_BPM_ACTIVITY=120
