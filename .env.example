# =================================
# HeartSync Connect - Environment Variables
# =================================
# Copia questo file in .env e compila con i tuoi valori reali

# ---------------------------------
# Database Configuration
# ---------------------------------
DATABASE_URL=postgresql://username:password@localhost:5432/heartsync

# ---------------------------------
# JWT Authentication
# ---------------------------------
# Genera chiavi sicure con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET_KEY=your-super-secret-refresh-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600  # 1 ora in secondi
JWT_REFRESH_TOKEN_EXPIRES=2592000  # 30 giorni in secondi

# ---------------------------------
# AWS S3 Configuration
# ---------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=heartsync-uploads
AWS_REGION=us-east-1

# ---------------------------------
# Stripe Payment
# ---------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# In produzione usa: sk_live_... e pk_live_...

# ---------------------------------
# Firebase Cloud Messaging
# ---------------------------------
FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk.json
# Scarica il file JSON dalle impostazioni Firebase

# ---------------------------------
# Application Environment
# ---------------------------------
ENVIRONMENT=development  # development | production
FRONTEND_URL=http://localhost:5173
# In produzione: https://tuodominio.com

# ---------------------------------
# Server Configuration
# ---------------------------------
BACKEND_PORT=5000
SOCKET_PORT=5001

# ---------------------------------
# Rate Limiting
# ---------------------------------
RATE_LIMIT_PER_MINUTE=100

# ---------------------------------
# File Upload Limits
# ---------------------------------
MAX_FILE_SIZE_MB=5
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# ---------------------------------
# Email Configuration (Optional)
# ---------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
FROM_EMAIL=noreply@heartsync.com

# ---------------------------------
# Logging
# ---------------------------------
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# ---------------------------------
# Security
# ---------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# In produzione: https://tuodominio.com

# ---------------------------------
# Development Only
# ---------------------------------
DEBUG=True  # Imposta False in produzione!
